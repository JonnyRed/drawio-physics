      <mxPoint x="40" y="70" as="sourcePoint"/>
      <mxPoint x="40" y="10" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="resultant_force" name="Resultant Force" title="Vector sum of forces" value="resultant" style="endArrow=classic;startArrow=none;html=1;strokeWidth=3;fillColor=none;strokeColor=#FF0000;dashed=4;" vertex="1">
    <mxGeometry width="100" height="100" as="geometry">
      <mxPoint x="10" y="50" as="sourcePoint"/>
      <mxPoint x="90" y="50" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="couple_moment" name="Couple/Moment" title="Rotational force pair or moment" value="couple" style="curved=1;html=1;strokeWidth=2;strokeColor=#FF0000;fillColor=none;endArrow=classic;startArrow=classic;dashed=2;" vertex="1">
    <mxGeometry width="80" height="80" as="geometry"/>
  </mxCell>

