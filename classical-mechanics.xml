      <mxPoint x="10" y="50" as="sourcePoint"/>
      <mxPoint x="90" y="50" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="trajectory" name="Trajectory" title="Motion path indicator" value="trajectory" style="curved=1;html=1;strokeWidth=1.5;strokeColor=#666666;fillColor=none;dashed=3;endArrow=classic;" vertex="1">
    <mxGeometry width="150" height="100" as="geometry"/>
  </mxCell>

  <mxCell id="applied_force" name="Applied Force" title="External push or pull" value="applied" style="endArrow=classic;startArrow=none;html=1;strokeWidth=2.5;fillColor=none;strokeColor=#00CC00;" vertex="1">
    <mxGeometry width="100" height="100" as="geometry">
      <mxPoint x="10" y="50" as="sourcePoint"/>
      <mxPoint x="90" y="50" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="component_x" name="Force Component (X)" title="Horizontal component of force" value="comp_x" style="endArrow=classic;startArrow=none;html=1;strokeWidth=2;fillColor=none;strokeColor=#FF9900;dashed=1;" vertex="1">
    <mxGeometry width="80" height="80" as="geometry">
      <mxPoint x="10" y="40" as="sourcePoint"/>
      <mxPoint x="70" y="40" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="component_y" name="Force Component (Y)" title="Vertical component of force" value="comp_y" style="endArrow=classic;startArrow=none;html=1;strokeWidth=2;fillColor=none;strokeColor=#FF9900;dashed=1;" vertex="1">
