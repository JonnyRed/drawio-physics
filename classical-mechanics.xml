      <mxPoint x="70" y="40" as="sourcePoint"/>
      <mxPoint x="10" y="40" as="targetPoint"/>
    </mxGeometry>
  </mxCell>

  <mxCell id="weld_rigid_bond" name="Weld/Rigid Bond" title="Permanent rigid connection" value="weld" style="line;html=1;strokeWidth=4;strokeColor=#000000;endArrow=none;" vertex="1">
    <mxGeometry width="100" height="10" as="geometry"/>
  </mxCell>

  <mxCell id="label_container" name="Label Container" title="Text box for variable labels" value="label" style="rounded=1;html=1;fontSize=12;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;" vertex="1">
