  </mxCell>

  <mxCell id="centripetal_force" name="Centripetal Force" title="Force toward center (circular motion)" value="centripetal" style="endArrow=classic;startArrow=none;html=1;strokeWidth=2.5;fillColor=none;strokeColor=#FF0000;" vertex="1">
