  </mxCell>

  <mxCell id="rough_surface" name="Rough Surface" title="Friction indicator (textured)" value="rough" style="path;html=1;strokeWidth=2;strokeColor=#666666;fillColor=#DDDDDD;" vertex="1">
    <mxGeometry width="120" height="20" as="geometry"/>
  </mxCell>

  <mxCell id="displacement_vector" name="Displacement" title="Position or path indicator" value="displacement" style="endArrow=classic;startArrow=none;html=1;strokeWidth=2;fillColor=none;strokeColor=#0066FF;dashed=3;" vertex="1">
