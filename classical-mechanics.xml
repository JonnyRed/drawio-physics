  </mxCell>

  <mxCell id="simple_box_mass" name="Simple Mass (Box)" title="Basic rectangular mass" value="box_mass" style="rectangle;html=1;fillColor=#FFE6E6;strokeColor=#CC0000;strokeWidth=2;rounded=0;" vertex="1">
    <mxGeometry width="50" height="50" as="geometry"/>
  </mxCell>

  <mxCell id="circle_mass" name="Circular Mass" title="Circular mass representation" value="circle_mass" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFE6E6;strokeColor=#CC0000;strokeWidth=2;" vertex="1">
