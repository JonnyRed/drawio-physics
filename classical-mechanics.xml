    <mxGeometry width="40" height="40" as="geometry"/>
  </mxCell>

  <mxCell id="axis_label_y" name="Axis Label (Y)" title="Y-axis indicator" value="axis_y" style="text;html=1;fontSize=14;fontStyle=bold;align=center;verticalAlign=middle;fontColor=#0066FF;" vertex="1">
    <mxGeometry width="40" height="40" as="geometry"/>
  </mxCell>

