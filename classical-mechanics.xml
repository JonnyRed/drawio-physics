  </mxCell>

  <mxCell id="magnitude_indicator" name="Magnitude Indicator" title="Show force or vector magnitude" value="magnitude" style="text;html=1;fontSize=11;fillColor=#FFFFCC;strokeColor=#FF9900;strokeWidth=1;align=center;verticalAlign=middle;" vertex="1">
