  </mxCell>

  <mxCell id="extended_beam" name="Beam/Rod" title="Rigid beam or rod element" value="beam" style="rectangle;html=1;fillColor=#D9D9D9;strokeColor=#333333;strokeWidth=2;rounded=0;" vertex="1">
